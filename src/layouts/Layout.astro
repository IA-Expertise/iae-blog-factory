---
import "../styles/global.css";
import SitePublicHeader from "../components/SitePublicHeader.astro";
import type { SiteData } from "../lib/cms";

interface Props {
  siteData: SiteData;
  title?: string;
  homeHref?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  noindex?: boolean;
  ogType?: "website" | "article";
  /** Home/post públicos do tenant: sem header padrão; o slot traz cabeçalho tenant + conteúdo. */
  tenantPublicLayout?: boolean;
}

const {
  siteData,
  title = siteData.brandName,
  homeHref = "/",
  description = `Conteudo sobre ${siteData.niche}`,
  canonicalUrl,
  ogImage = siteData.hero.image,
  noindex = false,
  ogType = "website",
  tenantPublicLayout = false
} = Astro.props;

const adsClient = siteData.ads.client?.trim() ?? "";
const adsenseScript =
  siteData.ads.enabled &&
  siteData.ads.provider === "adsense" &&
  /^ca-pub-\d{10,22}$/i.test(adsClient);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteData.brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:secure_url" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {
      adsenseScript && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${encodeURIComponent(adsClient)}`}
          crossorigin="anonymous"
        />
      )
    }
    <style
      define:vars={{
        colorPrimary: siteData.theme.primary,
        colorSecondary: siteData.theme.secondary,
        colorAccent: siteData.theme.accent,
        colorBg: siteData.theme.background,
        colorSurface: siteData.theme.surface,
        colorText: siteData.theme.text,
        fontHeading: siteData.theme.headingFont,
        fontBody: siteData.theme.bodyFont
      }}
    >
      :root {
        --color-primary: var(--colorPrimary);
        --color-secondary: var(--colorSecondary);
        --color-accent: var(--colorAccent);
        --color-bg: var(--colorBg);
        --color-surface: var(--colorSurface);
        --color-text: var(--colorText);
        --font-heading: var(--fontHeading);
        --font-body: var(--fontBody);
      }

      body {
        background: var(--color-bg);
        color: var(--color-text);
        font-family: var(--font-body);
      }

      h1,
      h2,
      h3,
      h4,
      h5,
      h6 {
        font-family: var(--font-heading);
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: auto;
        z-index: 50;
        padding: 0.5rem 1rem;
        border-radius: 0.5rem;
        background: var(--color-primary);
        color: #fff;
        font-weight: 600;
      }
      .skip-link:focus {
        left: 0.75rem;
        top: 0.75rem;
      }
    </style>
  </head>
  <body class:list={["min-h-screen antialiased", tenantPublicLayout && "overflow-x-hidden"]}>
    {
      tenantPublicLayout ? (
        <>
          <a class="skip-link" href="#conteudo">Ir para o conteúdo</a>
          <slot />
        </>
      ) : (
        <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
          <SitePublicHeader siteData={siteData} homeHref={homeHref} />
          <slot />
        </div>
      )
    }
  </body>
</html>
