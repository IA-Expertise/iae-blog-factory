---
import type { SiteData } from "../lib/cms";
import { resolvePublicAssetUrl } from "../lib/mediaUrl";
import {
  buildTenantArquivoPath,
  buildTenantContatoPath,
  buildTenantHomePath,
  buildTenantSobrePath
} from "../lib/tenantUrls";

interface Props {
  siteData: SiteData;
  active?: "home" | "sobre" | "arquivo" | "contato" | "other";
}

const { siteData, active = "other" } = Astro.props;
const h = siteData.hostname;
const homeHref = buildTenantHomePath(h);
/** Base escura da testeira; 30% opacidade sobre o fundo da página (70% transparente). */
const logoBarBase = "color-mix(in srgb, var(--color-primary) 82%, black)";
const logoBarBg = `color-mix(in srgb, ${logoBarBase} 30%, transparent)`;

const headerArtResolved = resolvePublicAssetUrl(siteData.headerArtUrl?.trim());
const hasHeaderArt = Boolean(headerArtResolved);

/** Sombra externa + bisel interno para sensação de profundidade 3D na testeira. */
const headerArtDepthStyle = hasHeaderArt
  ? [
      `background-image:url(${JSON.stringify(headerArtResolved)})`,
      "box-shadow:inset 0 1px 0 rgba(255,255,255,0.22),inset 0 -1px 0 rgba(0,0,0,0.14),0 2px 4px rgba(0,0,0,0.08),0 10px 28px -4px rgba(0,0,0,0.28),0 22px 48px -12px rgba(0,0,0,0.22)"
    ].join(";")
  : "";

function linkClass(key: NonNullable<Props["active"]>) {
  return active === key
    ? "font-semibold underline decoration-2 underline-offset-4"
    : "opacity-95 hover:underline hover:opacity-100";
}
---

<header class:list={["mb-6 space-y-0", !hasHeaderArt && "shadow-md"]}>
  {
    hasHeaderArt ? (
      <a
        href={homeHref}
        class="relative isolate block min-h-[11rem] w-full overflow-hidden rounded-t-2xl bg-[var(--color-bg)] bg-cover bg-[center_22%] ring-1 ring-black/20 sm:min-h-[14rem]"
        style={headerArtDepthStyle}
        aria-label={`Início — ${siteData.brandName}`}
      >
        <span
          class="pointer-events-none absolute inset-0 rounded-t-2xl shadow-[inset_0_0_100px_rgba(0,0,0,0.12),inset_0_2px_6px_rgba(0,0,0,0.08)]"
          aria-hidden="true"
        />
        <span
          class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-black/45 via-black/15 to-transparent sm:h-24"
          aria-hidden="true"
        />
      </a>
    ) : (
      <div
        class="flex items-center justify-start rounded-t-2xl px-5 py-4 sm:px-8 sm:py-5"
        style={`background: ${logoBarBg};`}
      >
        <a
          href={homeHref}
          class="flex shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-black/5 p-3 ring-1 ring-black/10 transition hover:bg-black/10 sm:p-4"
          aria-label={`Início — ${siteData.brandName}`}
        >
          {siteData.logoUrl ? (
            <img
              src={siteData.logoUrl}
              alt=""
              class="h-32 w-32 object-contain sm:h-36 sm:w-36"
              width="144"
              height="144"
              loading="eager"
            />
          ) : (
            <div class="flex h-32 w-32 items-center justify-center rounded-xl bg-black/10 text-4xl font-bold text-slate-800 sm:h-36 sm:w-36 sm:text-5xl">
              {siteData.brandName.trim().slice(0, 1).toUpperCase() || "?"}
            </div>
          )}
        </a>
      </div>
    )
  }
  <nav
    class="flex flex-wrap items-center justify-between gap-3 rounded-b-2xl bg-[#b91c1c] px-4 py-2.5 text-sm font-medium text-white sm:px-6"
    aria-label="Navegação secundária"
  >
    <div class="flex flex-wrap items-center gap-3">
      {
        siteData.social.instagram && (
          <a
            href={siteData.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-white/15 px-2 py-1 text-xs font-bold tracking-wide opacity-95 hover:bg-white/25"
            aria-label="Instagram"
          >
            IG
          </a>
        )
      }
      {
        siteData.social.facebook && (
          <a
            href={siteData.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-white/15 px-2 py-1 text-xs font-bold tracking-wide opacity-95 hover:bg-white/25"
            aria-label="Facebook"
          >
            FB
          </a>
        )
      }
      {
        siteData.social.youtube && (
          <a
            href={siteData.social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-white/15 px-2 py-1 text-xs font-bold tracking-wide opacity-95 hover:bg-white/25"
            aria-label="YouTube"
          >
            YT
          </a>
        )
      }
    </div>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
      <a href={buildTenantSobrePath(h)} class={linkClass("sobre")}>Quem somos?</a>
      <a href={buildTenantArquivoPath(h)} class={linkClass("arquivo")}>Arquivo</a>
      <a href={buildTenantContatoPath(h)} class={linkClass("contato")}>Contato</a>
    </div>
  </nav>
</header>
