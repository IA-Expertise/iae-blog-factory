---
interface Props {
  /** Link de afiliado gerado no SiteStripe */
  siteStripeLink: string;
}

const { siteStripeLink } = Astro.props;

const href = (siteStripeLink ?? "").trim();
const safeHref = href || "#";

const title = "IA na Sala de Aula";
const summary =
  "Um guia prático para aplicar inteligência artificial no contexto educacional, com estratégias acessíveis para professores e gestores.";

const fallbackCoverSvg = encodeURIComponent(`
<svg xmlns="http://www.w3.org/2000/svg" width="400" height="600" viewBox="0 0 400 600">
  <defs>
    <linearGradient id="g" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0" stop-color="#0f172a"/>
      <stop offset="1" stop-color="#1e40af"/>
    </linearGradient>
  </defs>
  <rect width="400" height="600" fill="url(#g)"/>
  <rect x="28" y="28" width="344" height="544" rx="16" fill="none" stroke="#93c5fd" stroke-width="2" opacity="0.45"/>
  <text x="42" y="120" fill="#dbeafe" font-family="Inter, Arial, sans-serif" font-size="28" font-weight="700">IA</text>
  <text x="42" y="165" fill="#dbeafe" font-family="Inter, Arial, sans-serif" font-size="28" font-weight="700">na Sala</text>
  <text x="42" y="210" fill="#dbeafe" font-family="Inter, Arial, sans-serif" font-size="28" font-weight="700">de Aula</text>
  <text x="42" y="510" fill="#bfdbfe" font-family="Inter, Arial, sans-serif" font-size="14">Livro recomendado</text>
</svg>
`);
const coverSrc = `data:image/svg+xml;charset=utf-8,${fallbackCoverSvg}`;
---

<aside
  class="rounded-2xl border bg-[var(--color-surface)] p-4 shadow-sm"
  style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);"
  aria-label="Destaque afiliado da Amazon"
>
  <p class="mb-2 text-xs uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">Amazon</p>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-[120px_1fr]">
    <img
      src={coverSrc}
      alt={`Capa do livro ${title}`}
      class="w-full rounded-xl object-cover"
      width="400"
      height="600"
      loading="lazy"
      decoding="async"
    />

    <div>
      <h3 class="text-lg font-semibold" style="color: var(--color-text);">{title}</h3>
      <p class="mt-2 text-sm" style="color: color-mix(in srgb, var(--color-text) 78%, transparent);">{summary}</p>

      <a
        href={safeHref}
        class="mt-4 inline-block rounded-lg px-4 py-2 text-sm font-semibold text-white transition-opacity hover:opacity-90"
        style="background: var(--color-primary);"
        target="_blank"
        rel="noopener noreferrer sponsored"
        aria-disabled={!href}
      >
        Comprar na Amazon
      </a>
    </div>
  </div>
</aside>
