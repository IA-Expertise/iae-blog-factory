---
interface Props {
  provider: string;
  client: string;
  slot: string;
  /** `banner`: faixa larga no topo; `card`: bloco lateral/padrão */
  layout?: "card" | "banner";
}

const { provider, client, slot, layout = "card" } = Astro.props;

const isAdsense = provider.toLowerCase() === "adsense";
const clientId = client?.trim() ?? "";
const slotId = slot?.trim() ?? "";
/** ID de editor no formato Google (apenas dígitos após ca-pub-). */
const validClient = /^ca-pub-\d{10,22}$/i.test(clientId);
/** Bloco de anúncio: o slot no painel AdSense é numérico. */
const validSlot = /^\d{6,12}$/.test(slotId);
const renderAdsense = isAdsense && validClient && validSlot;
const isBanner = layout === "banner";
---

<aside
  class:list={[
    "border bg-[var(--color-surface)] shadow-sm",
    isBanner ? "w-full rounded-none border-x-0 px-0 py-3 sm:rounded-2xl sm:border sm:px-4" : "rounded-2xl p-4"
  ]}
  style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);"
>
  <p class="mb-2 text-xs uppercase tracking-wide px-1 sm:px-0" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">Publicidade</p>
  {
    renderAdsense ? (
      <div
        class:list={["overflow-hidden", isBanner ? "min-h-[90px] rounded-none sm:rounded-xl" : "min-h-[100px] rounded-xl"]}
        style="background: color-mix(in srgb, var(--color-surface) 88%, white);"
      >
        <ins
          class="adsbygoogle"
          style={isBanner ? "display:block; min-height:90px;" : "display:block; min-height:100px;"}
          data-ad-client={clientId}
          data-ad-slot={slotId}
          data-ad-format="auto"
          data-full-width-responsive="true"
        />
        <script is:inline>
          (adsbygoogle = window.adsbygoogle || []).push({});
        </script>
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-amber-200 bg-amber-50/80 p-4 text-sm text-amber-950">
        <p class="font-semibold">AdSense (pré-visualização)</p>
        {!isAdsense && <p>Provedor: {provider}</p>}
        {isAdsense && !validClient && (
          <p class="mt-1">
            No painel <strong>Monetização</strong>, use um ID de cliente no formato <code class="rounded bg-white px-1">ca-pub-XXXXXXXXXX</code> (só números após
            <code class="rounded bg-white px-1">ca-pub-</code>), o mesmo que aparece no código que o Google pede para colar no site.
          </p>
        )}
        {isAdsense && validClient && !validSlot && (
          <p class="mt-1">
            Cliente: <code class="rounded bg-white px-1">{clientId}</code>. O <strong>slot</strong> precisa ser o <strong>ID numérico</strong> do bloco de anúncios (Anúncios
            → Por unidade de anúncios), não um nome como “sidebar”.
          </p>
        )}
        <p class="mt-2 text-xs text-amber-800/90">
          Anúncios reais só aparecem depois que o domínio estiver aprovado no AdSense e os IDs forem os do teu painel.
        </p>
      </div>
    )
  }
</aside>
