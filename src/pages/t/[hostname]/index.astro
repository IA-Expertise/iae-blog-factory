---
import Layout from "../../../layouts/Layout.astro";
import AdUnit from "../../../components/AdUnit.astro";
import AffiliateWidget from "../../../components/AffiliateWidget.astro";
import TenantPublicHeader from "../../../components/TenantPublicHeader.astro";
import { getSiteDataByHostname } from "../../../lib/cms";
import { resolvePublicAssetUrl } from "../../../lib/mediaUrl";
import { buildTenantHomePath, buildTenantPostPath, normalizeTenantHostname } from "../../../lib/tenantUrls";

export const prerender = false;

const hostname = Astro.params.hostname ?? "";
const siteData = await getSiteDataByHostname(hostname);
const [heroPost, ...secondaryPosts] = siteData.posts;
const homeHref = buildTenantHomePath(siteData.hostname);
const canonicalUrl = new URL(homeHref, Astro.url.origin).toString();
const description = `${siteData.brandName}: conteudo sobre ${siteData.niche} com guias, dicas e artigos atualizados.`;
const ogImage = siteData.hero.image;
const requestedHostname = normalizeTenantHostname(hostname);

if (requestedHostname !== siteData.hostname) {
  return Astro.redirect(homeHref);
}

const MID_AD_AFTER = 6;
const showMidFeedAd = secondaryPosts.length >= MID_AD_AFTER;
const firstChunk = showMidFeedAd ? secondaryPosts.slice(0, MID_AD_AFTER) : secondaryPosts;
const tailChunk = showMidFeedAd ? secondaryPosts.slice(MID_AD_AFTER) : [];
---

<Layout
  siteData={siteData}
  title={`${siteData.brandName} | Home`}
  homeHref={homeHref}
  canonicalUrl={canonicalUrl}
  description={description}
  ogImage={ogImage}
  ogType="website"
  tenantPublicLayout={true}
>
  {
    siteData.ads.enabled && (
      <div class="border-b pb-3" style="border-color: color-mix(in srgb, var(--color-text) 12%, transparent);">
        <div class="mx-auto min-w-0 max-w-7xl px-4 sm:px-6 lg:px-8">
          <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.topSlot} layout="banner" />
        </div>
      </div>
    )
  }

  <div class="mx-auto min-w-0 max-w-7xl px-4 pb-10 pt-4 sm:px-6 lg:px-8">
    <TenantPublicHeader siteData={siteData} active="home" />

    <div id="conteudo" class="grid min-w-0 grid-cols-1 gap-8 lg:grid-cols-12">
      <main class="min-w-0 space-y-8 lg:col-span-8">
        {
          heroPost && (
            <section aria-labelledby="destaque-titulo">
              <h2 id="destaque-titulo" class="mb-3 text-xl font-bold">Artigo em destaque</h2>
              <article class="min-w-0 rounded-2xl border bg-[var(--color-surface)] p-5 shadow-sm" style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);">
                <img
                  src={resolvePublicAssetUrl(heroPost.image)}
                  alt={heroPost.title}
                  class="h-56 w-full max-w-full rounded-xl object-cover"
                  width="1200"
                  height="630"
                  sizes="(max-width: 1024px) 100vw, 896px"
                  loading="eager"
                  decoding="async"
                />
                <div class="mt-4">
                  <p class="text-xs uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{heroPost.category}</p>
                  <h3 class="mt-2 text-2xl font-bold">
                    <a href={buildTenantPostPath(siteData.hostname, heroPost.slug ?? "")} class="hover:underline">{heroPost.title}</a>
                  </h3>
                  <p class="mt-1 text-sm" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{heroPost.publishedAt}</p>
                </div>
              </article>
            </section>
          )
        }

        {
          siteData.affiliate.enabled && siteData.affiliate.products.length > 0 && (
            <AffiliateWidget
              network={siteData.affiliate.network}
              trackingId={siteData.affiliate.trackingId}
              products={siteData.affiliate.products}
              maxProducts={3}
            />
          )
        }

        {
          siteData.rssFeedUrl && (
            <section class="rounded-2xl border bg-[var(--color-surface)] p-4 shadow-sm" style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);">
              <p class="text-xs uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">Feed RSS</p>
              <p class="mt-1 text-sm" style="color: color-mix(in srgb, var(--color-text) 78%, transparent);">
                Acompanhe as novidades também pelo feed RSS.
              </p>
              <a
                href={siteData.rssFeedUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-3 inline-flex rounded-lg px-4 py-2 text-sm font-semibold text-white transition hover:opacity-90"
                style="background: var(--color-primary);"
              >
                Abrir feed RSS
              </a>
            </section>
          )
        }

        {
          siteData.ads.enabled && (
            <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.inContentSlot} layout="banner" />
          )
        }

        <section aria-labelledby="mais-lidos">
          <h2 id="mais-lidos" class="mb-4 text-2xl font-bold">Mais lidos</h2>
          <div class="grid min-w-0 grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
            {
              firstChunk.map((post) => (
                <article class="group min-w-0 overflow-hidden rounded-2xl border bg-[var(--color-surface)] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);">
                  <img
                    src={resolvePublicAssetUrl(post.image)}
                    alt={post.title}
                    class="h-44 w-full max-w-full object-cover"
                    width="800"
                    height="450"
                    sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 320px"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="p-4">
                    <p class="text-xs uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{post.category}</p>
                    <h3 class="mt-1 line-clamp-2 text-lg font-semibold">
                      <a href={buildTenantPostPath(siteData.hostname, post.slug ?? "")} class="hover:underline">{post.title}</a>
                    </h3>
                    <p class="mt-2 text-sm" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{post.publishedAt}</p>
                  </div>
                </article>
              ))}
          </div>
        </section>

        {
          showMidFeedAd && siteData.ads.enabled && (
            <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.footerSlot} layout="banner" />
          )
        }

        {
          tailChunk.length > 0 && (
            <div class="grid min-w-0 grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
              {tailChunk.map((post) => (
                <article class="group min-w-0 overflow-hidden rounded-2xl border bg-[var(--color-surface)] shadow-sm transition hover:-translate-y-0.5 hover:shadow-md" style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);">
                  <img
                    src={resolvePublicAssetUrl(post.image)}
                    alt={post.title}
                    class="h-44 w-full max-w-full object-cover"
                    width="800"
                    height="450"
                    sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 320px"
                    loading="lazy"
                    decoding="async"
                  />
                  <div class="p-4">
                    <p class="text-xs uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{post.category}</p>
                    <h3 class="mt-1 line-clamp-2 text-lg font-semibold">
                      <a href={buildTenantPostPath(siteData.hostname, post.slug ?? "")} class="hover:underline">{post.title}</a>
                    </h3>
                    <p class="mt-2 text-sm" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{post.publishedAt}</p>
                  </div>
                </article>
              ))}
            </div>
          )
        }
      </main>

      <aside class="min-w-0 space-y-4 lg:sticky lg:top-4 lg:col-span-4 lg:self-start">
        {siteData.ads.enabled && <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.sidebarSlot} />}
      </aside>
    </div>

    <footer class="mt-10 rounded-2xl px-4 py-4 text-center text-sm text-white" style="background: var(--color-primary);">
      {siteData.contact.footerText ?? `© ${new Date().getFullYear()} ${siteData.brandName}`}
    </footer>
  </div>
</Layout>
