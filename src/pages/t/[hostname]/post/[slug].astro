---
import Layout from "../../../../layouts/Layout.astro";
import AdUnit from "../../../../components/AdUnit.astro";
import AffiliateWidget from "../../../../components/AffiliateWidget.astro";
import TenantPublicHeader from "../../../../components/TenantPublicHeader.astro";
import { getPublishedPostBySlug, getSiteDataByHostname } from "../../../../lib/cms";
import { renderPostMarkdown } from "../../../../lib/renderMarkdown";
import { resolvePublicAssetUrl } from "../../../../lib/mediaUrl";
import { buildTenantHomePath, buildTenantPostPath, normalizeTenantHostname, normalizeTenantSlug } from "../../../../lib/tenantUrls";

export const prerender = false;

const hostname = Astro.params.hostname ?? "";
const slug = Astro.params.slug ?? "";
const siteData = await getSiteDataByHostname(hostname);
const post = await getPublishedPostBySlug(siteData.hostname, slug);
const articleHtml = post?.content ? renderPostMarkdown(post.content) : "";
const coverSrc = post ? resolvePublicAssetUrl(post.image) : "";
const homeHref = buildTenantHomePath(siteData.hostname);
const requestedHostname = normalizeTenantHostname(hostname);
const requestedSlug = normalizeTenantSlug(slug);

if (!post) {
  return Astro.redirect(homeHref);
}

const canonicalPostPath = buildTenantPostPath(siteData.hostname, post.slug ?? "");
if (requestedHostname !== siteData.hostname || requestedSlug !== (post.slug ?? "")) {
  return Astro.redirect(canonicalPostPath);
}

const configuredPublicOrigin = import.meta.env.PUBLIC_SITE_ORIGIN?.trim()?.replace(/\/+$/, "") ?? "";
const requestOrigin = Astro.url.origin;
const useConfiguredOrigin =
  configuredPublicOrigin.length > 0 &&
  (Astro.url.hostname === "localhost" || Astro.url.hostname === "127.0.0.1" || Astro.url.hostname === "::1");
const publicOrigin = useConfiguredOrigin ? configuredPublicOrigin : requestOrigin;
const canonicalUrl = new URL(canonicalPostPath, `${publicOrigin}/`).toString();
const ogImageUrl = new URL(coverSrc || siteData.hero.image, `${publicOrigin}/`).toString();
const description = post.excerpt?.trim() || `Leia ${post.title} em ${siteData.brandName}.`;
const encodedUrl = encodeURIComponent(canonicalUrl);
const encodedTitle = encodeURIComponent(post.title);
const shareLinks = {
  whatsapp: `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  x: `https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
  telegram: `https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`
};
---

<Layout
  siteData={siteData}
  title={`${post.title} | ${siteData.brandName}`}
  homeHref={homeHref}
  canonicalUrl={canonicalUrl}
  description={description}
  ogImage={ogImageUrl}
  ogType="article"
  tenantPublicLayout={true}
>
  <div class="mx-auto min-w-0 max-w-7xl space-y-6 px-4 pb-10 pt-4 sm:px-6 lg:px-8">
    <TenantPublicHeader siteData={siteData} active="other" />

    {siteData.ads.enabled && (
      <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.topSlot} layout="banner" />
    )}

    <div id="conteudo" class="grid min-w-0 grid-cols-1 gap-6 lg:grid-cols-12">
      <article class="min-w-0 space-y-4 lg:col-span-8">
        <div class="space-y-2">
          <p class="text-xs uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{post.category}</p>
          <h1 class="text-3xl font-bold leading-tight sm:text-4xl" style="color: var(--color-text);">{post.title}</h1>
          <p class="text-sm" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">{post.publishedAt}</p>
        </div>
        <section
          aria-label="Compartilhar artigo"
          class="rounded-2xl border bg-[var(--color-surface)] p-4 shadow-sm"
          style="border-color: color-mix(in srgb, var(--color-text) 16%, transparent);"
        >
          <p class="mb-3 text-xs font-semibold uppercase tracking-wide" style="color: color-mix(in srgb, var(--color-text) 55%, transparent);">
            Compartilhe
          </p>
          <div class="flex flex-wrap gap-2">
            <a href={shareLinks.whatsapp} target="_blank" rel="noopener noreferrer" class="rounded-lg border px-3 py-1.5 text-sm font-medium hover:bg-black/5" style="border-color: color-mix(in srgb, var(--color-text) 20%, transparent);">WhatsApp</a>
            <a href={shareLinks.facebook} target="_blank" rel="noopener noreferrer" class="rounded-lg border px-3 py-1.5 text-sm font-medium hover:bg-black/5" style="border-color: color-mix(in srgb, var(--color-text) 20%, transparent);">Facebook</a>
            <a href={shareLinks.x} target="_blank" rel="noopener noreferrer" class="rounded-lg border px-3 py-1.5 text-sm font-medium hover:bg-black/5" style="border-color: color-mix(in srgb, var(--color-text) 20%, transparent);">X</a>
            <a href={shareLinks.linkedin} target="_blank" rel="noopener noreferrer" class="rounded-lg border px-3 py-1.5 text-sm font-medium hover:bg-black/5" style="border-color: color-mix(in srgb, var(--color-text) 20%, transparent);">LinkedIn</a>
            <a href={shareLinks.telegram} target="_blank" rel="noopener noreferrer" class="rounded-lg border px-3 py-1.5 text-sm font-medium hover:bg-black/5" style="border-color: color-mix(in srgb, var(--color-text) 20%, transparent);">Telegram</a>
            <button
              type="button"
              class="rounded-lg border px-3 py-1.5 text-sm font-medium hover:bg-black/5"
              style="border-color: color-mix(in srgb, var(--color-text) 20%, transparent);"
              data-copy-link
            >
              Copiar link
            </button>
          </div>
        </section>
        {coverSrc ? (
          <img
            src={coverSrc}
            alt={post.title}
            class="h-64 w-full max-w-full rounded-2xl object-cover sm:h-72"
            width="1200"
            height="630"
            sizes="(max-width: 1024px) 100vw, 896px"
            loading="eager"
            decoding="async"
          />
        ) : null}
        <div class="rounded-2xl bg-[var(--color-surface)] p-5 shadow-sm">
          {post.content ? (
            <div
              class="prose prose-lg max-w-none prose-img:max-w-full prose-headings:font-bold prose-headings:tracking-tight prose-h2:mt-10 prose-h2:text-2xl prose-h3:mt-8 prose-h3:text-xl prose-p:leading-relaxed prose-li:marker:opacity-50 prose-a:font-medium prose-a:text-[var(--color-accent)] prose-a:underline-offset-2 hover:prose-a:underline"
              style="color: color-mix(in srgb, var(--color-text) 92%, transparent); --tw-prose-headings: var(--color-text);"
              set:html={articleHtml}
            />
          ) : (
            <p class="text-base leading-relaxed" style="color: color-mix(in srgb, var(--color-text) 78%, transparent);">{post.excerpt}</p>
          )}
        </div>

        {siteData.affiliate.enabled && (
          <AffiliateWidget
            network={siteData.affiliate.network}
            trackingId={siteData.affiliate.trackingId}
            products={siteData.affiliate.products}
            maxProducts={3}
          />
        )}

        {siteData.ads.enabled && (
          <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.inContentSlot} />
        )}
      </article>

      <aside class="min-w-0 space-y-4 lg:sticky lg:top-4 lg:col-span-4 lg:self-start">
        {siteData.ads.enabled && (
          <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.sidebarSlot} />
        )}
      </aside>
    </div>

    {siteData.ads.enabled && (
      <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.footerSlot} />
    )}

    <footer class="rounded-2xl bg-[var(--color-primary)] p-4 text-center text-sm text-white">
      {siteData.contact.footerText ?? `© ${new Date().getFullYear()} ${siteData.brandName}`}
    </footer>
  </div>
  <script is:inline>
    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const button = target.closest("[data-copy-link]");
      if (!(button instanceof HTMLButtonElement)) return;
      try {
        await navigator.clipboard.writeText(window.location.href);
        const previous = button.textContent;
        button.textContent = "Link copiado!";
        window.setTimeout(() => {
          button.textContent = previous;
        }, 1600);
      } catch {
        button.textContent = "Falhou ao copiar";
      }
    });
  </script>
</Layout>
