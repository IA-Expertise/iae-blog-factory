---
import Layout from "../../layouts/Layout.astro";
import AdUnit from "../../components/AdUnit.astro";
import AffiliateWidget from "../../components/AffiliateWidget.astro";
import { getPublishedPostBySlug } from "../../lib/cms";
import { resolvePublicOrigin } from "../../lib/publicOrigin";
import { renderPostMarkdown } from "../../lib/renderMarkdown";
import { resolvePublicAssetUrl } from "../../lib/mediaUrl";
import { buildTenantPostPath } from "../../lib/tenantUrls";

export const prerender = false;

const siteData = Astro.locals.siteData;
const slug = Astro.params.slug ?? "";
const post = await getPublishedPostBySlug(siteData.hostname, slug);
const articleHtml = post?.content ? renderPostMarkdown(post.content) : "";
const coverSrc = post ? resolvePublicAssetUrl(post.image) : "";
const publicOrigin = resolvePublicOrigin(Astro.request.url, Astro.request);

if (!post) {
  return Astro.redirect("/");
}

const canonicalPostPath = buildTenantPostPath(siteData.hostname, post.slug ?? "");
if (Astro.url.pathname !== canonicalPostPath) {
  return Astro.redirect(canonicalPostPath);
}
const resolvedImageUrl = new URL(coverSrc || siteData.hero.image, `${publicOrigin}/`).toString();
const ogImageUrl = resolvedImageUrl.startsWith(`${publicOrigin}/`)
  ? resolvedImageUrl
  : new URL(`/api/media/proxy?src=${encodeURIComponent(resolvedImageUrl)}`, `${publicOrigin}/`).toString();
---

<Layout
  siteData={siteData}
  title={`${post.title} | ${siteData.brandName}`}
  noindex={true}
  canonicalUrl={new URL(`/t/${siteData.hostname}/post/${post.slug ?? ""}`, `${publicOrigin}/`).toString()}
  ogImage={ogImageUrl}
>
  <div class="space-y-6">
    {siteData.ads.enabled && (
      <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.topSlot} />
    )}

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
      <article class="space-y-4 lg:col-span-8">
        <div class="space-y-2">
          <p class="text-xs uppercase tracking-wide text-slate-500">{post.category}</p>
          <h1 class="text-3xl font-bold leading-tight text-slate-900 sm:text-4xl">{post.title}</h1>
          <p class="text-sm text-slate-500">{post.publishedAt}</p>
        </div>
        {
          coverSrc ? (
            <img src={coverSrc} alt={post.title} class="h-64 w-full rounded-2xl object-cover sm:h-72" loading="eager" />
          ) : null
        }
        <div class="rounded-2xl bg-[var(--color-surface)] p-5 shadow-sm">
          {post.content ? (
            <div
              class="prose prose-lg max-w-none text-slate-800 prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-slate-900 prose-h2:mt-10 prose-h2:text-2xl prose-h3:mt-8 prose-h3:text-xl prose-p:leading-relaxed prose-li:marker:text-slate-400 prose-a:font-medium prose-a:text-[var(--color-accent)] prose-a:underline-offset-2 hover:prose-a:underline"
              set:html={articleHtml}
            />
          ) : (
            <p class="text-base leading-relaxed text-slate-600">{post.excerpt}</p>
          )}
        </div>

        {siteData.affiliate.enabled && (
          <AffiliateWidget
            network={siteData.affiliate.network}
            trackingId={siteData.affiliate.trackingId}
            products={siteData.affiliate.products}
          />
        )}

        {siteData.ads.enabled && (
          <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.inContentSlot} />
        )}
      </article>

      <aside class="space-y-4 lg:col-span-4">
        {siteData.ads.enabled && (
          <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.sidebarSlot} />
        )}
      </aside>
    </div>

    {siteData.ads.enabled && (
      <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.footerSlot} />
    )}

    <footer class="rounded-2xl bg-[var(--color-primary)] p-4 text-center text-sm text-white">
      {siteData.contact.footerText ?? `© ${new Date().getFullYear()} ${siteData.brandName}`}
    </footer>
  </div>
</Layout>
