---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../lib/adminAuth";

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const steps = [
  { title: "Dominio e DNS", body: "Compre o dominio e crie um CNAME apontando para o Railway. No Railway, adicione o dominio customizado ao servico web." },
  { title: "Tenant com hostname real", body: "Em Tenants, cadastre o hostname exato do cliente (ex: blog.cliente.com) para o tema e conteudo carregarem." },
  { title: "Variaveis de ambiente", body: "Confirme DATABASE_URL, ADMIN_USER, ADMIN_PASSWORD, OPENAI_API_KEY e CRON_SECRET no Railway." },
  { title: "Banco aplicado", body: "O deploy roda prisma db push no start. Se precisar, rode novamente no shell do Railway." },
  { title: "Cron de publicacao", body: "Agende uma chamada periodica para /api/cron/publish?key=CRON_SECRET (ex: a cada 5-15 minutos) para liberar posts agendados." },
  { title: "Google AdSense e afiliados", body: "Ajuste client/slot do AdSense e produtos afiliados em Tenants e Afiliados." },
  {
    title: "Fluxo editorial",
    body: "No Gerador: briefing, pautas do mes, aprovacao e geracao de artigos. Revise em Posts, use o calendario e o cron para publicar agendados."
  }
];
---

<AdminLayout title="Go-live | IAE Blog Factory">
  <section class="rounded-2xl bg-white p-5 shadow-sm">
    <h2 class="text-xl font-semibold">Checklist de go-live</h2>
    <p class="mt-1 text-sm text-slate-500">Use esta lista antes de apresentar o site ao cliente.</p>
    <ol class="mt-6 space-y-4">
      {steps.map((step, index) => (
        <li class="flex gap-3 rounded-xl border border-slate-100 bg-slate-50 p-4">
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-slate-900 text-sm font-bold text-white">
            {index + 1}
          </span>
          <div>
            <p class="font-semibold">{step.title}</p>
            <p class="mt-1 text-sm text-slate-600">{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
    <div class="mt-6 flex flex-wrap gap-2">
      <a class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white" href="/admin/tenants">
        Abrir Tenants
      </a>
      <a class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white" href="/admin/affiliates">
        Abrir Afiliados
      </a>
      <a class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white" href="/admin/calendar">
        Ver calendario
      </a>
    </div>
  </section>
</AdminLayout>
