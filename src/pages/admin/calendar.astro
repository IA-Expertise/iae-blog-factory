---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../lib/adminAuth";
import { listScheduledPostsForCalendar } from "../../lib/cms";

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const items = await listScheduledPostsForCalendar();
const sorted = [...items].sort(
  (a, b) => new Date(a.scheduledPublishAt).getTime() - new Date(b.scheduledPublishAt).getTime()
);

const groups = new Map<string, typeof sorted>();
for (const item of sorted) {
  const label = new Date(item.scheduledPublishAt).toLocaleDateString("pt-BR", {
    weekday: "long",
    day: "2-digit",
    month: "long",
    year: "numeric"
  });
  const list = groups.get(label) ?? [];
  list.push(item);
  groups.set(label, list);
}

const groupEntries = [...groups.entries()].sort(
  (a, b) => new Date(a[1][0].scheduledPublishAt).getTime() - new Date(b[1][0].scheduledPublishAt).getTime()
);
---

<AdminLayout title="Calendario | IAE Blog Factory">
  <section class="rounded-2xl bg-white p-5 shadow-sm">
    <h2 class="text-xl font-semibold">Publicacoes agendadas</h2>
    <p class="mt-1 text-sm text-slate-500">Posts com data de publicacao definida (status APROVADO ate o cron publicar).</p>
  </section>

  {items.length === 0 ? (
    <p class="mt-6 rounded-2xl bg-white p-6 text-center text-slate-500 shadow-sm">Nenhum agendamento no momento.</p>
  ) : (
    <div class="mt-6 space-y-6">
      {groupEntries.map(([day, posts]) => (
        <article class="rounded-2xl bg-white p-5 shadow-sm">
          <h3 class="text-lg font-semibold capitalize">{day}</h3>
          <ul class="mt-3 space-y-2">
            {posts.map((p) => (
              <li class="flex flex-wrap items-center justify-between gap-2 rounded-lg border border-slate-100 px-3 py-2">
                <div>
                  <p class="font-medium">{p.title}</p>
                  <p class="text-xs text-slate-500">
                    {p.hostname} -{" "}
                    {new Date(p.scheduledPublishAt).toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" })}
                  </p>
                </div>
                <a class="text-sm font-semibold text-indigo-600 hover:underline" href={`/admin/post/${p.id}`}>
                  Abrir
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  )}
</AdminLayout>
