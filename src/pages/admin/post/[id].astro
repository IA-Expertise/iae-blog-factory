---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../../lib/adminAuth";
import { resolvePublicOrigin } from "../../../lib/publicOrigin";
import { buildTenantPostPath } from "../../../lib/tenantUrls";
import {
  getPostById,
  publishPostNow,
  regeneratePostCover,
  schedulePostPublication,
  setPostStatus,
  updatePostFields,
  type PostStatus
} from "../../../lib/cms";

export const prerender = false;

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const { id } = Astro.params;
if (!id) {
  return Astro.redirect("/admin/posts");
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") ?? "");

  if (action === "save") {
    await updatePostFields(id, {
      title: String(formData.get("title") ?? ""),
      slug: String(formData.get("slug") ?? ""),
      category: String(formData.get("category") ?? ""),
      image: String(formData.get("image") ?? ""),
      excerpt: String(formData.get("excerpt") ?? ""),
      content: String(formData.get("content") ?? "")
    });
  }

  if (action === "to_review") {
    await setPostStatus(id, "IN_REVIEW");
  }

  if (action === "approve") {
    await setPostStatus(id, "APPROVED");
  }

  if (action === "publish_now") {
    await publishPostNow(id);
  }

  if (action === "regenerate_image") {
    await regeneratePostCover(id);
  }

  if (action === "schedule") {
    const raw = String(formData.get("scheduledAt") ?? "");
    const tzRaw = Number.parseInt(String(formData.get("tzOffsetMinutes") ?? ""), 10);
    const tz = Number.isFinite(tzRaw) ? tzRaw : null;
    await schedulePostPublication(id, raw, tz);
  }

  return Astro.redirect(`/admin/post/${id}`);
}

const row = await getPostById(id);
if (!row) {
  return Astro.redirect("/admin/posts");
}

const publicOrigin = resolvePublicOrigin(Astro.request.url, Astro.request);
const postUrl = new URL(buildTenantPostPath(row.tenant.hostname, row.slug), `${publicOrigin}/`).toString();
const socialBase = `${row.title}\n\n${row.excerpt ?? "Confira este conteúdo no blog."}`.trim();
const instagramCaption = `${socialBase}\n\nLeia mais no link da bio.\n#historia #noticias #blog`;
const facebookCaption = `${socialBase}\n\nLeia a matéria completa:\n${postUrl}`;
const xCaption = `${row.title}\n\nLeia a matéria completa: ${postUrl}`;
const linkedinCaption = `${socialBase}\n\nAcesse o conteúdo completo: ${postUrl}`;

const statusLabel: Record<PostStatus, string> = {
  DRAFT: "Rascunho",
  IN_REVIEW: "Em revisao",
  APPROVED: "Aprovado (aguardando publicacao ou agendamento)",
  PUBLISHED: "Publicado no site"
};
---

<AdminLayout title={`Editar post | ${row.title}`}>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-wide text-slate-500">Status atual</p>
      <p class="text-lg font-semibold">{statusLabel[row.status as PostStatus]}</p>
      <p class="text-sm text-slate-500">{row.tenant.hostname}</p>
    </div>
    <a class="rounded-lg bg-slate-200 px-3 py-2 text-sm font-medium text-slate-800 hover:bg-slate-300" href="/admin/posts">
      Voltar para lista
    </a>
  </div>

  <form method="POST" class="space-y-6 rounded-2xl bg-white p-5 shadow-sm">
    <div class="grid gap-4 md:grid-cols-2">
      <label class="text-sm">
        <span class="mb-1 block font-medium">Titulo</span>
        <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="title" value={row.title} required />
      </label>
      <label class="text-sm">
        <span class="mb-1 block font-medium">Slug</span>
        <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="slug" value={row.slug} required />
      </label>
      <label class="text-sm">
        <span class="mb-1 block font-medium">Categoria</span>
        <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="category" value={row.category} required />
      </label>
      <label class="text-sm md:col-span-2">
        <span class="mb-1 block font-medium">URL da imagem de capa</span>
        <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="image" value={row.image} required />
      </label>
    </div>
    <label class="text-sm">
      <span class="mb-1 block font-medium">Resumo (excerpt)</span>
      <textarea class="min-h-[80px] w-full rounded-lg border border-slate-300 px-3 py-2" name="excerpt">{row.excerpt ?? ""}</textarea>
    </label>
    <label class="text-sm">
      <span class="mb-1 block font-medium">Conteudo (markdown)</span>
      <textarea class="min-h-[280px] w-full rounded-lg border border-slate-300 px-3 py-2 font-mono text-sm" name="content">{row.content ?? ""}</textarea>
    </label>
    <button
      class="rounded-lg bg-indigo-600 px-4 py-2 font-semibold text-white hover:bg-indigo-500"
      type="submit"
      name="action"
      value="save"
    >
      Salvar alteracoes
    </button>
    <button
      class="ml-2 rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700"
      type="submit"
      name="action"
      value="regenerate_image"
    >
      Regenerar imagem
    </button>
  </form>

  <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-semibold">Fluxo editorial</h2>
    <p class="mt-1 text-sm text-slate-500">Rascunho → revisao → aprovacao → agendar ou publicar agora.</p>

    <div class="mt-4 flex flex-wrap gap-2">
      <form method="POST">
        <input type="hidden" name="action" value="to_review" />
        <button
          class="rounded-lg bg-amber-600 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-500 disabled:opacity-40"
          type="submit"
          disabled={row.status !== "DRAFT"}
        >
          Enviar para revisao
        </button>
      </form>

      <form method="POST">
        <input type="hidden" name="action" value="approve" />
        <button
          class="rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-500 disabled:opacity-40"
          type="submit"
          disabled={row.status !== "IN_REVIEW"}
        >
          Aprovar
        </button>
      </form>

      <form method="POST">
        <input type="hidden" name="action" value="publish_now" />
        <button
          class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-500 disabled:opacity-40"
          type="submit"
          disabled={row.status !== "APPROVED"}
        >
          Publicar agora
        </button>
      </form>
    </div>

    <form method="POST" class="mt-6 grid gap-3 rounded-xl border border-slate-200 p-4 md:grid-cols-3">
      <input type="hidden" name="action" value="schedule" />
      <input type="hidden" name="tzOffsetMinutes" value="" data-tz-offset />
      <label class="text-sm md:col-span-2">
        <span class="mb-1 block font-medium">Agendar publicacao</span>
        <input
          class="w-full rounded-lg border border-slate-300 px-3 py-2"
          type="datetime-local"
          name="scheduledAt"
          required
        />
      </label>
      <div class="flex items-end">
        <button
          class="w-full rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700 disabled:opacity-40"
          type="submit"
          disabled={row.status === "PUBLISHED" || row.status === "DRAFT" || row.status === "IN_REVIEW"}
        >
          Agendar
        </button>
      </div>
      <p class="text-xs text-slate-500 md:col-span-3">
        O post precisa estar aprovado ou voce pode aprovar antes. Ao agendar, o status fica APROVADO ate a data. Configure um cron no Railway chamando
        <code class="rounded bg-slate-100 px-1">/api/cron/publish?key=CRON_SECRET</code>.
      </p>
    </form>
  </section>
  <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-lg font-semibold">Social (Fase 1)</h2>
    <p class="mt-1 text-sm text-slate-500">
      Gera peças prontas por rede com disparo assistido. O post no site não é alterado por este bloco.
    </p>
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      <article class="rounded-xl border border-slate-200 p-4">
        <div class="mb-2 flex items-center justify-between">
          <p class="font-semibold">Instagram</p>
          <span class="rounded bg-fuchsia-100 px-2 py-0.5 text-xs font-semibold text-fuchsia-800">Assistido</span>
        </div>
        <textarea class="min-h-[120px] w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" data-social-caption="instagram">{instagramCaption}</textarea>
        <div class="mt-3 flex flex-wrap gap-2">
          <button class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700" type="button" data-social-disparar="instagram">
            Disparar
          </button>
          <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium hover:bg-slate-50" type="button" data-social-programar="instagram">
            Programar
          </button>
        </div>
      </article>

      <article class="rounded-xl border border-slate-200 p-4">
        <div class="mb-2 flex items-center justify-between">
          <p class="font-semibold">Facebook</p>
          <span class="rounded bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-800">Link share</span>
        </div>
        <textarea class="min-h-[120px] w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" data-social-caption="facebook">{facebookCaption}</textarea>
        <div class="mt-3 flex flex-wrap gap-2">
          <button class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700" type="button" data-social-disparar="facebook">
            Disparar
          </button>
          <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium hover:bg-slate-50" type="button" data-social-programar="facebook">
            Programar
          </button>
        </div>
      </article>

      <article class="rounded-xl border border-slate-200 p-4">
        <div class="mb-2 flex items-center justify-between">
          <p class="font-semibold">X (Twitter)</p>
          <span class="rounded bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-700">Link share</span>
        </div>
        <textarea class="min-h-[120px] w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" data-social-caption="x">{xCaption}</textarea>
        <div class="mt-3 flex flex-wrap gap-2">
          <button class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700" type="button" data-social-disparar="x">
            Disparar
          </button>
          <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium hover:bg-slate-50" type="button" data-social-programar="x">
            Programar
          </button>
        </div>
      </article>

      <article class="rounded-xl border border-slate-200 p-4">
        <div class="mb-2 flex items-center justify-between">
          <p class="font-semibold">LinkedIn</p>
          <span class="rounded bg-sky-100 px-2 py-0.5 text-xs font-semibold text-sky-800">Link share</span>
        </div>
        <textarea class="min-h-[120px] w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" data-social-caption="linkedin">{linkedinCaption}</textarea>
        <div class="mt-3 flex flex-wrap gap-2">
          <button class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700" type="button" data-social-disparar="linkedin">
            Disparar
          </button>
          <button class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium hover:bg-slate-50" type="button" data-social-programar="linkedin">
            Programar
          </button>
        </div>
      </article>
    </div>
    <p class="mt-3 text-xs text-slate-500">
      Dica: “Disparar” abre o fluxo da rede com o link. Em plataformas com limitação (ex.: Instagram), copiamos legenda + link e abrimos o app.
    </p>
  </section>
  <script is:inline define:vars={{ postUrl }}>

    function getCaption(network) {
      const el = document.querySelector(`[data-social-caption="${network}"]`);
      if (!(el instanceof HTMLTextAreaElement)) return "";
      return el.value.trim();
    }

    async function copyToClipboard(text) {
      try {
        await navigator.clipboard.writeText(text);
        return true;
      } catch {
        return false;
      }
    }

    function openShare(network, caption) {
      const encodedUrl = encodeURIComponent(postUrl);
      const encodedCaption = encodeURIComponent(caption);
      const shareMap = {
        facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
        x: `https://x.com/intent/tweet?text=${encodedCaption}`,
        linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`
      };
      const target = shareMap[network];
      if (target) window.open(target, "_blank", "noopener,noreferrer");
    }

    function openScheduleReminder(network, caption) {
      const now = new Date();
      const start = new Date(now.getTime() + 30 * 60 * 1000);
      const end = new Date(start.getTime() + 15 * 60 * 1000);
      const toGCal = (d) =>
        `${d.getUTCFullYear()}${String(d.getUTCMonth() + 1).padStart(2, "0")}${String(d.getUTCDate()).padStart(2, "0")}T${String(
          d.getUTCHours()
        ).padStart(2, "0")}${String(d.getUTCMinutes()).padStart(2, "0")}00Z`;
      const text = encodeURIComponent(`Publicar card no ${network.toUpperCase()} — ${document.title}`);
      const details = encodeURIComponent(`${caption}\n\nLink do post: ${postUrl}`);
      const href = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${text}&details=${details}&dates=${toGCal(start)}/${toGCal(end)}`;
      window.open(href, "_blank", "noopener,noreferrer");
    }

    document.addEventListener("click", async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const dispararBtn = target.closest("[data-social-disparar]");
      if (dispararBtn instanceof HTMLButtonElement) {
        const network = dispararBtn.getAttribute("data-social-disparar");
        if (!network) return;
        const caption = getCaption(network);
        if (network === "instagram") {
          await copyToClipboard(`${caption}\n\n${postUrl}`);
          window.open("https://www.instagram.com/", "_blank", "noopener,noreferrer");
          return;
        }
        openShare(network, `${caption}\n${postUrl}`);
        return;
      }

      const programarBtn = target.closest("[data-social-programar]");
      if (programarBtn instanceof HTMLButtonElement) {
        const network = programarBtn.getAttribute("data-social-programar");
        if (!network) return;
        const caption = getCaption(network);
        openScheduleReminder(network, caption);
      }
    });

    const tzField = document.querySelector("[data-tz-offset]");
    if (tzField instanceof HTMLInputElement) {
      tzField.value = String(new Date().getTimezoneOffset());
    }
  </script>
</AdminLayout>
