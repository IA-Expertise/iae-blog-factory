---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../lib/adminAuth";
import { listCommentsForAdmin, listCommentTenants, updateCommentStatus, type CommentStatus } from "../../lib/comments";
import { buildTenantPostPath } from "../../lib/tenantUrls";

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const PAGE_SIZE = 20;
const currentUrl = new URL(Astro.request.url);

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") ?? "");
  const id = String(formData.get("commentId") ?? "");
  const status = String(formData.get("status") ?? "") as CommentStatus;

  if (action === "set_status" && id && status) {
    await updateCommentStatus({ id, status });
  }

  const params = new URLSearchParams();
  const hostname = String(formData.get("hostname") ?? "");
  const statusFilter = String(formData.get("statusFilter") ?? "");
  const search = String(formData.get("search") ?? "");
  const page = String(formData.get("page") ?? "");
  if (hostname) params.set("hostname", hostname);
  if (statusFilter) params.set("status", statusFilter);
  if (search.trim()) params.set("search", search.trim());
  if (page && page !== "1") params.set("page", page);
  const query = params.toString();
  return Astro.redirect(query ? `/admin/comments?${query}` : "/admin/comments");
}

const tenants = await listCommentTenants();
const selectedHostname = currentUrl.searchParams.get("hostname") ?? "all";
const statusFilter = (currentUrl.searchParams.get("status") ?? "all").toUpperCase();
const search = (currentUrl.searchParams.get("search") ?? "").trim();
const pageParam = Number.parseInt(currentUrl.searchParams.get("page") ?? "1", 10);
const page = Number.isFinite(pageParam) && pageParam > 0 ? pageParam : 1;

const commentsResult = await listCommentsForAdmin({
  hostname: selectedHostname === "all" ? undefined : selectedHostname,
  status: statusFilter,
  search,
  page,
  pageSize: PAGE_SIZE
});

const totalPages = Math.max(1, Math.ceil(commentsResult.total / PAGE_SIZE));
const safePage = Math.min(page, totalPages);

const queryForPage = (targetPage: number) => {
  const p = new URLSearchParams();
  if (selectedHostname !== "all") p.set("hostname", selectedHostname);
  if (statusFilter !== "ALL") p.set("status", statusFilter.toLowerCase());
  if (search) p.set("search", search);
  if (targetPage > 1) p.set("page", String(targetPage));
  return p.toString();
};

const statusBadge: Record<string, string> = {
  PUBLISHED: "bg-emerald-200 text-emerald-900",
  AUTO_HIDDEN: "bg-amber-200 text-amber-900",
  HIDDEN: "bg-slate-200 text-slate-700",
  DELETED: "bg-rose-200 text-rose-900"
};
---

<AdminLayout title="Comentários | IAE Blog Factory">
  <section class="rounded-2xl bg-white p-5 shadow-sm">
    <h2 class="text-xl font-semibold">Comentários (auto-moderação)</h2>
    <p class="mt-1 text-sm text-slate-500">
      Publicados entram automático. Suspeitos ficam ocultos para revisão rápida.
    </p>

    <form method="GET" class="mt-4 grid gap-3 md:grid-cols-4">
      <label class="text-sm">
        <span class="mb-1 block font-medium">Tenant</span>
        <select class="w-full rounded-lg border border-slate-300 px-3 py-2" name="hostname">
          <option value="all" selected={selectedHostname === "all"}>Todos</option>
          {tenants.map((tenant) => (
            <option value={tenant.hostname} selected={tenant.hostname === selectedHostname}>
              {tenant.hostname}
            </option>
          ))}
        </select>
      </label>
      <label class="text-sm">
        <span class="mb-1 block font-medium">Status</span>
        <select class="w-full rounded-lg border border-slate-300 px-3 py-2" name="status">
          <option value="all" selected={statusFilter === "ALL"}>Todos</option>
          <option value="published" selected={statusFilter === "PUBLISHED"}>Publicados</option>
          <option value="auto_hidden" selected={statusFilter === "AUTO_HIDDEN"}>Auto ocultos</option>
          <option value="hidden" selected={statusFilter === "HIDDEN"}>Ocultos</option>
          <option value="deleted" selected={statusFilter === "DELETED"}>Excluídos</option>
        </select>
      </label>
      <label class="text-sm md:col-span-2">
        <span class="mb-1 block font-medium">Busca</span>
        <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="search" value={search} placeholder="Nome, conteúdo ou título do post" />
      </label>
      <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-700 md:col-span-4 md:w-fit" type="submit">
        Aplicar filtros
      </button>
    </form>
  </section>

  <section class="mt-6 rounded-2xl bg-white p-5 shadow-sm">
    {commentsResult.items.length === 0 ? (
      <p class="text-sm text-slate-500">Nenhum comentário encontrado com os filtros atuais.</p>
    ) : (
      <ul class="space-y-3">
        {commentsResult.items.map((comment) => (
          <li class="rounded-xl border border-slate-200 p-4">
            <div class="flex flex-wrap items-center gap-2">
              <span class={`rounded-full px-2 py-0.5 text-xs font-semibold ${statusBadge[comment.status] ?? "bg-slate-100 text-slate-700"}`}>
                {comment.status}
              </span>
              <span class="rounded bg-slate-100 px-2 py-0.5 text-xs text-slate-600">{comment.tenantHostname}</span>
              {comment.isFlagged && (
                <span class="rounded bg-amber-100 px-2 py-0.5 text-xs text-amber-900">
                  Sinalizado: {comment.flagReason ?? "regra automática"}
                </span>
              )}
              <span class="text-xs text-slate-500">{new Date(comment.createdAt).toLocaleString("pt-BR")}</span>
            </div>

            <p class="mt-2 text-sm font-semibold">{comment.authorName}</p>
            {comment.authorEmail && <p class="text-xs text-slate-500">{comment.authorEmail}</p>}
            <p class="mt-2 whitespace-pre-wrap text-sm text-slate-800">{comment.content}</p>

            <div class="mt-3 flex flex-wrap items-center gap-2">
              <a
                class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold hover:bg-slate-50"
                href={buildTenantPostPath(comment.tenantHostname, comment.postSlug)}
                target="_blank"
                rel="noopener noreferrer"
              >
                Ver post
              </a>
              <form method="POST">
                <input type="hidden" name="action" value="set_status" />
                <input type="hidden" name="commentId" value={comment.id} />
                <input type="hidden" name="status" value="PUBLISHED" />
                <input type="hidden" name="hostname" value={selectedHostname} />
                <input type="hidden" name="statusFilter" value={statusFilter.toLowerCase()} />
                <input type="hidden" name="search" value={search} />
                <input type="hidden" name="page" value={String(safePage)} />
                <button class="rounded-lg bg-emerald-700 px-3 py-1.5 text-xs font-semibold text-white hover:bg-emerald-600" type="submit">
                  Publicar
                </button>
              </form>
              <form method="POST">
                <input type="hidden" name="action" value="set_status" />
                <input type="hidden" name="commentId" value={comment.id} />
                <input type="hidden" name="status" value="HIDDEN" />
                <input type="hidden" name="hostname" value={selectedHostname} />
                <input type="hidden" name="statusFilter" value={statusFilter.toLowerCase()} />
                <input type="hidden" name="search" value={search} />
                <input type="hidden" name="page" value={String(safePage)} />
                <button class="rounded-lg bg-slate-700 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-600" type="submit">
                  Ocultar
                </button>
              </form>
              <form method="POST">
                <input type="hidden" name="action" value="set_status" />
                <input type="hidden" name="commentId" value={comment.id} />
                <input type="hidden" name="status" value="DELETED" />
                <input type="hidden" name="hostname" value={selectedHostname} />
                <input type="hidden" name="statusFilter" value={statusFilter.toLowerCase()} />
                <input type="hidden" name="search" value={search} />
                <input type="hidden" name="page" value={String(safePage)} />
                <button class="rounded-lg bg-rose-700 px-3 py-1.5 text-xs font-semibold text-white hover:bg-rose-600" type="submit">
                  Excluir
                </button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}

    <div class="mt-4 flex items-center justify-between text-sm">
      <p class="text-slate-500">Página {safePage} de {totalPages}</p>
      <div class="flex gap-2">
        {safePage > 1 ? (
          <a class="rounded-lg border border-slate-300 px-3 py-1.5 hover:bg-slate-50" href={`/admin/comments?${queryForPage(safePage - 1)}`}>
            Anterior
          </a>
        ) : (
          <span class="rounded-lg border border-slate-200 px-3 py-1.5 text-slate-400">Anterior</span>
        )}
        {safePage < totalPages ? (
          <a class="rounded-lg border border-slate-300 px-3 py-1.5 hover:bg-slate-50" href={`/admin/comments?${queryForPage(safePage + 1)}`}>
            Próxima
          </a>
        ) : (
          <span class="rounded-lg border border-slate-200 px-3 py-1.5 text-slate-400">Próxima</span>
        )}
      </div>
    </div>
  </section>
</AdminLayout>
