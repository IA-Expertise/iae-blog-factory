---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../lib/adminAuth";
import {
  listPitches,
  listSites,
  replaceSuggestedPitches,
  setPitchStatus,
  writeArticlesFromApprovedPitches,
  type PitchStatus
} from "../../lib/cms";
import { generateMonthlyPitches } from "../../lib/contentGenerator";

export const prerender = false;

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const sites = await listSites();
const url = new URL(Astro.request.url);
const ok = url.searchParams.get("ok");
const err = url.searchParams.get("err");
const written = url.searchParams.get("written");

const defaultMonth = () => {
  const d = new Date();
  const m = `${d.getMonth() + 1}`.padStart(2, "0");
  return `${d.getFullYear()}-${m}`;
};

let selectedHost = url.searchParams.get("hostname") ?? sites[0]?.hostname ?? "";
let monthKey = url.searchParams.get("month") ?? defaultMonth();

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") ?? "");
  const hostname = String(formData.get("hostname") ?? "");

  try {
    if (action === "suggest_pitches") {
      const m = String(formData.get("monthKey") ?? defaultMonth());
      const count = Math.min(20, Math.max(3, parseInt(String(formData.get("pitchCount") ?? "8"), 10) || 8));
      const site = sites.find((s) => s.hostname === hostname);
      if (!site) throw new Error("Tenant nao encontrado.");

      const ideas = await generateMonthlyPitches({
        tenantName: site.brandName,
        niche: site.niche,
        monthLabel: m,
        count,
        brief: site.editorial.projectDescription ?? "",
        styleNotes: `${site.editorial.editorialStyleNotes ?? ""}\nPublico-alvo: ${site.editorial.targetAudience ?? ""}`.trim(),
        tone: site.editorial.defaultArticleTone ?? "profissional"
      });

      await replaceSuggestedPitches(
        hostname,
        m,
        ideas.map((p) => ({ title: p.title, summary: p.summary }))
      );
      return Astro.redirect(`/admin/generator?hostname=${encodeURIComponent(hostname)}&month=${encodeURIComponent(m)}&ok=pitches`);
    }

    if (action === "set_pitch_status") {
      const pitchId = String(formData.get("pitchId") ?? "");
      const status = String(formData.get("status") ?? "") as PitchStatus;
      await setPitchStatus(hostname, pitchId, status);
      const m = String(formData.get("monthKey") ?? defaultMonth());
      return Astro.redirect(`/admin/generator?hostname=${encodeURIComponent(hostname)}&month=${encodeURIComponent(m)}&ok=pitch`);
    }

    if (action === "write_articles") {
      const m = String(formData.get("monthKey") ?? defaultMonth());
      const n = await writeArticlesFromApprovedPitches(hostname, m);
      return Astro.redirect(
        `/admin/generator?hostname=${encodeURIComponent(hostname)}&month=${encodeURIComponent(m)}&written=${n}`
      );
    }
  } catch (e) {
    const msg = e instanceof Error ? e.message : "erro";
    const m = String(formData.get("monthKey") ?? defaultMonth());
    return Astro.redirect(
      `/admin/generator?hostname=${encodeURIComponent(hostname)}&month=${encodeURIComponent(m)}&err=${encodeURIComponent(msg)}`
    );
  }
}

const site = sites.find((s) => s.hostname === selectedHost) ?? sites[0];
if (site) {
  selectedHost = site.hostname;
}
const pitches = site ? await listPitches(selectedHost, monthKey) : [];
---

<AdminLayout title="Gerador de artigos | IAE Blog Factory">
  <section class="mb-6 rounded-2xl border border-indigo-100 bg-indigo-50 p-5 text-sm text-indigo-950">
    <h2 class="text-lg font-semibold text-indigo-950">Fluxo simples do gerador</h2>
    <ol class="mt-3 list-decimal space-y-1 pl-5">
      <li>Selecione tenant e mês.</li>
      <li>Peça sugestões de pautas.</li>
      <li>Aprove/rejeite as pautas.</li>
      <li>Clique em gerar artigos para criar os rascunhos automaticamente.</li>
    </ol>
    <p class="mt-3 text-xs text-indigo-900">
      As informações de projeto/estilo/público ficam em <a class="font-semibold underline" href="/admin/tenants">Tenants</a>.
    </p>
  </section>

  {ok === "pitches" && <p class="mb-4 rounded-lg bg-emerald-100 px-3 py-2 text-sm text-emerald-900">Novas pautas sugeridas.</p>}
  {ok === "pitch" && <p class="mb-4 rounded-lg bg-emerald-100 px-3 py-2 text-sm text-emerald-900">Status da pauta atualizado.</p>}
  {written && (
    <p class="mb-4 rounded-lg bg-emerald-100 px-3 py-2 text-sm text-emerald-900">
      Artigos gerados: {written}. Abra <a class="font-semibold underline" href="/admin/posts">Posts</a> para revisar.
    </p>
  )}
  {err && <p class="mb-4 rounded-lg bg-rose-100 px-3 py-2 text-sm text-rose-900">Erro: {err}</p>}

  <form method="get" class="mb-6 flex flex-wrap items-end gap-3 rounded-2xl bg-white p-4 shadow-sm">
    <label class="text-sm">
      <span class="mb-1 block font-medium">Tenant</span>
      <select class="rounded-lg border border-slate-300 px-3 py-2" name="hostname">
        {sites.map((s) => (
          <option value={s.hostname} selected={s.hostname === selectedHost}>
            {s.hostname}
          </option>
        ))}
      </select>
    </label>
    <label class="text-sm">
      <span class="mb-1 block font-medium">Mes (AAAA-MM)</span>
      <input class="rounded-lg border border-slate-300 px-3 py-2" type="month" name="month" value={monthKey} />
    </label>
    <button class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white" type="submit">
      Aplicar
    </button>
  </form>

  {site && (
    <>
      <section class="mt-6 rounded-2xl bg-white p-5 shadow-sm">
        <h2 class="text-xl font-semibold">Sugerir pautas do mês (IA)</h2>
        <p class="mt-1 text-sm text-slate-500">Gera titulos e resumos. Pautas antigas em status Sugerido serao substituidas.</p>
        <form method="POST" class="mt-4 flex flex-wrap items-end gap-3">
          <input type="hidden" name="action" value="suggest_pitches" />
          <input type="hidden" name="hostname" value={selectedHost} />
          <label class="text-sm">
            <span class="mb-1 block font-medium">Mes</span>
            <input class="rounded-lg border border-slate-300 px-3 py-2" type="month" name="monthKey" value={monthKey} required />
          </label>
          <label class="text-sm">
            <span class="mb-1 block font-medium">Quantidade</span>
            <input class="w-24 rounded-lg border border-slate-300 px-3 py-2" type="number" name="pitchCount" min="3" max="20" value="8" />
          </label>
          <button class="rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700" type="submit">
            Sugerir pautas
          </button>
        </form>
      </section>

      <section class="mt-6 rounded-2xl bg-white p-5 shadow-sm">
        <h2 class="text-xl font-semibold">Aprovar pautas</h2>
        {pitches.length === 0 ? (
          <p class="mt-2 text-sm text-slate-500">Nenhuma pauta para este mes ainda. Gere sugestoes acima.</p>
        ) : (
          <ul class="mt-4 space-y-3">
            {pitches.map((p) => (
              <li class="rounded-xl border border-slate-200 p-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0 flex-1">
                    <span
                      class={`mb-2 inline-block rounded-full px-2 py-0.5 text-xs font-semibold ${
                        p.status === "SUGGESTED"
                          ? "bg-slate-200 text-slate-800"
                          : p.status === "APPROVED"
                            ? "bg-sky-200 text-sky-900"
                            : p.status === "REJECTED"
                              ? "bg-rose-200 text-rose-900"
                              : "bg-emerald-200 text-emerald-900"
                      }`}
                    >
                      {p.status}
                    </span>
                    <p class="font-semibold">{p.title}</p>
                    <p class="mt-1 text-sm text-slate-600">{p.summary}</p>
                  </div>
                  <div class="flex flex-wrap gap-2">
                    {p.status === "SUGGESTED" && (
                      <>
                        <form method="POST">
                          <input type="hidden" name="action" value="set_pitch_status" />
                          <input type="hidden" name="hostname" value={selectedHost} />
                          <input type="hidden" name="monthKey" value={monthKey} />
                          <input type="hidden" name="pitchId" value={p.id} />
                          <input type="hidden" name="status" value="APPROVED" />
                          <button class="rounded-lg bg-sky-600 px-3 py-1.5 text-sm font-semibold text-white" type="submit">
                            Aprovar
                          </button>
                        </form>
                        <form method="POST">
                          <input type="hidden" name="action" value="set_pitch_status" />
                          <input type="hidden" name="hostname" value={selectedHost} />
                          <input type="hidden" name="monthKey" value={monthKey} />
                          <input type="hidden" name="pitchId" value={p.id} />
                          <input type="hidden" name="status" value="REJECTED" />
                          <button class="rounded-lg bg-rose-600 px-3 py-1.5 text-sm font-semibold text-white" type="submit">
                            Rejeitar
                          </button>
                        </form>
                      </>
                    )}
                    {p.status === "APPROVED" && (
                      <form method="POST">
                        <input type="hidden" name="action" value="set_pitch_status" />
                        <input type="hidden" name="hostname" value={selectedHost} />
                        <input type="hidden" name="monthKey" value={monthKey} />
                        <input type="hidden" name="pitchId" value={p.id} />
                        <input type="hidden" name="status" value="SUGGESTED" />
                        <button class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm" type="submit">
                          Voltar para sugerido
                        </button>
                      </form>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section class="mt-6 rounded-2xl bg-white p-5 shadow-sm">
        <h2 class="text-xl font-semibold">Gerar artigos das pautas aprovadas</h2>
        <p class="mt-1 text-sm text-slate-500">
          Cria rascunhos com texto e imagem. Se o tenant tiver dias e hora UTC configurados, os posts saem como <strong>APROVADO + agendado</strong>.
        </p>
        <form method="POST" class="mt-4">
          <input type="hidden" name="action" value="write_articles" />
          <input type="hidden" name="hostname" value={selectedHost} />
          <input type="hidden" name="monthKey" value={monthKey} />
          <button class="rounded-lg bg-emerald-600 px-4 py-2 font-semibold text-white hover:bg-emerald-500" type="submit">
            Gerar artigos (pautas APROVADAS deste mes)
          </button>
        </form>
      </section>
    </>
  )}
</AdminLayout>
