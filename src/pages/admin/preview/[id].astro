---
import Layout from "../../../layouts/Layout.astro";
import AdUnit from "../../../components/AdUnit.astro";
import AffiliateWidget from "../../../components/AffiliateWidget.astro";
import { isAdminAuthenticated } from "../../../lib/adminAuth";
import { getPostById, getTenantByHostname } from "../../../lib/cms";
import { renderPostMarkdown } from "../../../lib/renderMarkdown";
import { resolvePublicAssetUrl } from "../../../lib/mediaUrl";

export const prerender = false;

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const { id } = Astro.params;
if (!id) return Astro.redirect("/admin/posts");

const row = await getPostById(id);
if (!row) return Astro.redirect("/admin/posts");

const siteData = await getTenantByHostname(row.tenant.hostname);
if (!siteData) return Astro.redirect("/admin/posts");

const articleHtml = row.content ? renderPostMarkdown(row.content) : "";
const coverSrc = resolvePublicAssetUrl(row.image);
---

<Layout siteData={siteData} title={`Preview | ${row.title}`}>
  <div class="space-y-6">
    <div class="rounded-xl border border-amber-300 bg-amber-50 px-4 py-2 text-sm text-amber-900">
      Pré-visualização de template (admin). Este post pode estar em rascunho.
    </div>

    {siteData.ads.enabled && (
      <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.topSlot} />
    )}

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12">
      <article class="space-y-4 lg:col-span-8">
        <div class="space-y-2">
          <p class="text-xs uppercase tracking-wide text-slate-500">{row.category}</p>
          <h1 class="text-3xl font-bold leading-tight text-slate-900 sm:text-4xl">{row.title}</h1>
        </div>
        {
          coverSrc ? (
            <img src={coverSrc} alt={row.title} class="h-64 w-full rounded-2xl object-cover sm:h-72" loading="eager" />
          ) : null
        }
        <div class="rounded-2xl bg-[var(--color-surface)] p-5 shadow-sm">
          {row.content ? (
            <div
              class="prose prose-lg max-w-none text-slate-800 prose-headings:font-bold prose-headings:tracking-tight prose-headings:text-slate-900 prose-h2:mt-10 prose-h2:text-2xl prose-h3:mt-8 prose-h3:text-xl prose-p:leading-relaxed prose-li:marker:text-slate-400 prose-a:font-medium prose-a:text-[var(--color-accent)] prose-a:underline-offset-2 hover:prose-a:underline"
              set:html={articleHtml}
            />
          ) : (
            <p class="text-base leading-relaxed text-slate-600">{row.excerpt}</p>
          )}
        </div>
        {siteData.affiliate.enabled && (
          <AffiliateWidget
            network={siteData.affiliate.network}
            trackingId={siteData.affiliate.trackingId}
            products={siteData.affiliate.products}
          />
        )}
      </article>

      <aside class="space-y-4 lg:col-span-4">
        {siteData.ads.enabled && (
          <AdUnit provider={siteData.ads.provider} client={siteData.ads.client} slot={siteData.ads.sidebarSlot} />
        )}
      </aside>
    </div>
  </div>
</Layout>
