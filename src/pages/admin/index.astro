---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../lib/adminAuth";
import { listSites } from "../../lib/cms";
import { resolvePublicOrigin } from "../../lib/publicOrigin";
import { buildTenantPublicUrl } from "../../lib/tenantUrls";

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

const sites = await listSites();
const totalPosts = sites.reduce((acc, site) => acc + site.posts.length, 0);
const origin = resolvePublicOrigin(Astro.request.url, Astro.request);
const statusTotals = sites.reduce(
  (acc, site) => {
    for (const post of site.posts) {
      acc[post.status] = (acc[post.status] ?? 0) + 1;
    }
    return acc;
  },
  { DRAFT: 0, IN_REVIEW: 0, APPROVED: 0, PUBLISHED: 0 } as Record<string, number>
);
const siteSummaries = sites.map((site) => {
  const counts = site.posts.reduce(
    (acc, post) => {
      acc[post.status] = (acc[post.status] ?? 0) + 1;
      return acc;
    },
    { DRAFT: 0, IN_REVIEW: 0, APPROVED: 0, PUBLISHED: 0 } as Record<string, number>
  );
  return {
    site,
    counts,
    latest: site.posts[0] ?? null
  };
});
---

<AdminLayout title="Dashboard | IAE Blog Factory">
  <section class="grid gap-4 md:grid-cols-3">
    <article class="rounded-2xl bg-white p-5 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Tenants</p>
      <p class="mt-2 text-3xl font-bold">{sites.length}</p>
    </article>
    <article class="rounded-2xl bg-white p-5 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Posts</p>
      <p class="mt-2 text-3xl font-bold">{totalPosts}</p>
    </article>
    <article class="rounded-2xl bg-white p-5 shadow-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Status</p>
      <p class="mt-2 text-lg font-semibold text-emerald-600">Operando</p>
      <div class="mt-2 flex flex-wrap gap-1 text-xs">
        <span class="rounded bg-slate-100 px-2 py-0.5">Rasc: {statusTotals.DRAFT ?? 0}</span>
        <span class="rounded bg-amber-100 px-2 py-0.5">Rev: {statusTotals.IN_REVIEW ?? 0}</span>
        <span class="rounded bg-sky-100 px-2 py-0.5">Apr: {statusTotals.APPROVED ?? 0}</span>
        <span class="rounded bg-emerald-100 px-2 py-0.5">Pub: {statusTotals.PUBLISHED ?? 0}</span>
      </div>
    </article>
  </section>

  <section class="mt-6 flex flex-wrap gap-2 rounded-2xl bg-white p-5 shadow-sm">
    <a class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-700" href="/admin/posts">
      Posts e revisao
    </a>
    <a class="rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500" href="/admin/generator">
      Gerador IA
    </a>
    <a class="rounded-lg bg-slate-200 px-3 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-300" href="/admin/monetization">
      Monetização
    </a>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-semibold">Visão Geral por blog</h2>
    <div class="mt-4 grid gap-4 lg:grid-cols-2">
      {siteSummaries.map(({ site, counts, latest }) => (
        <article class="rounded-2xl bg-white p-5 shadow-sm">
          <div class="flex flex-wrap items-start justify-between gap-2">
            <div>
              <h3 class="text-lg font-semibold">{site.brandName}</h3>
              <p class="text-sm text-slate-500">{site.hostname}</p>
            </div>
            <a
              class="rounded-lg bg-slate-900 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-700"
              href={buildTenantPublicUrl(origin, site.hostname)}
              target="_blank"
              rel="noopener noreferrer"
            >
              Abrir blog
            </a>
          </div>

          <p class="mt-2 text-sm text-slate-600">Nicho: {site.niche}</p>
          <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold">
            <span class="rounded bg-slate-100 px-2 py-0.5">Rascunhos: {counts.DRAFT ?? 0}</span>
            <span class="rounded bg-amber-100 px-2 py-0.5">Revisão: {counts.IN_REVIEW ?? 0}</span>
            <span class="rounded bg-sky-100 px-2 py-0.5">Aprovados: {counts.APPROVED ?? 0}</span>
            <span class="rounded bg-emerald-100 px-2 py-0.5">Publicados: {counts.PUBLISHED ?? 0}</span>
          </div>
          <p class="mt-3 text-sm text-slate-600">
            Último post: {latest ? latest.title : "Nenhum post"}
          </p>
          <div class="mt-3 flex flex-wrap gap-2">
            <a class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold hover:bg-slate-50" href={`/admin/posts?hostname=${encodeURIComponent(site.hostname)}`}>
              Ver posts
            </a>
            <a class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold hover:bg-slate-50" href={`/admin/generator?hostname=${encodeURIComponent(site.hostname)}`}>
              Ver gerador
            </a>
            <a class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold hover:bg-slate-50" href={`/admin/tenants?hostname=${encodeURIComponent(site.hostname)}`}>
              Configurar
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</AdminLayout>
