---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { isAdminAuthenticated } from "../../lib/adminAuth";
import { copyTenantVisualSettings, createTenant, getTenantByHostname, listSites, updateTenantSettings } from "../../lib/cms";
import { isObjectStorageConfigured, uploadPublicImageAsset } from "../../lib/objectStorage";
import { resolvePublicOrigin } from "../../lib/publicOrigin";
import { buildTenantPublicUrl } from "../../lib/tenantUrls";

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = String(formData.get("action") ?? "");

  if (action === "create") {
    try {
      const createdHostname = await createTenant({
        hostname: String(formData.get("hostname") ?? ""),
        brandName: String(formData.get("brandName") ?? ""),
        niche: String(formData.get("niche") ?? "")
      });
      return Astro.redirect(`/admin/tenants?hostname=${encodeURIComponent(createdHostname)}&ok=1`);
    } catch (error) {
      const message = error instanceof Error ? error.message : "Nao foi possivel criar o tenant.";
      return Astro.redirect(`/admin/tenants?err=${encodeURIComponent(message)}`);
    }
  }

  if (action === "save") {
    const hostname = String(formData.get("hostname") ?? "");
    try {
      let logoUrl = String(formData.get("logoUrl") ?? "");
      let headerArtUrl = String(formData.get("headerArtUrl") ?? "");
      const logoFile = formData.get("logoFile");
      const headerArtFile = formData.get("headerArtFile");
      const hasUpload = logoFile instanceof File && logoFile.size > 0;
      const hasHeaderArtUpload = headerArtFile instanceof File && headerArtFile.size > 0;

      if (hasUpload) {
        if (!isObjectStorageConfigured()) {
          throw new Error("Upload indisponivel: configure o object storage (R2/S3) no ambiente.");
        }
        const logo = logoFile as File;
        if (!/^image\/(png|jpe?g|webp)$/i.test(logo.type)) {
          throw new Error("Formato de logo invalido. Use PNG, JPG ou WEBP.");
        }
        const extension = logo.type.includes("png") ? "png" : logo.type.includes("webp") ? "webp" : "jpg";
        const safeHost = hostname.toLowerCase().replace(/[^a-z0-9.-]/g, "-");
        const keyName = `${safeHost}-${Date.now()}.${extension}`;
        const uploadedUrl = await uploadPublicImageAsset({
          buffer: Buffer.from(await logo.arrayBuffer()),
          objectPath: `logos/${keyName}`,
          contentType: logo.type
        });
        if (!uploadedUrl) {
          throw new Error("Falha ao enviar logo para o storage.");
        }
        logoUrl = uploadedUrl;
      }

      if (hasHeaderArtUpload) {
        if (!isObjectStorageConfigured()) {
          throw new Error("Upload indisponivel: configure o object storage (R2/S3) no ambiente.");
        }
        const art = headerArtFile as File;
        if (!/^image\/(png|jpe?g|webp)$/i.test(art.type)) {
          throw new Error("Formato de arte da testeira invalido. Use PNG, JPG ou WEBP.");
        }
        const ext = art.type.includes("png") ? "png" : art.type.includes("webp") ? "webp" : "jpg";
        const safeHost = hostname.toLowerCase().replace(/[^a-z0-9.-]/g, "-");
        const artKey = `${safeHost}-header-${Date.now()}.${ext}`;
        const artUploaded = await uploadPublicImageAsset({
          buffer: Buffer.from(await art.arrayBuffer()),
          objectPath: `headers/${artKey}`,
          contentType: art.type
        });
        if (!artUploaded) {
          throw new Error("Falha ao enviar arte da testeira para o storage.");
        }
        headerArtUrl = artUploaded;
      }

      await updateTenantSettings({
        hostname,
        brandName: String(formData.get("brandName") ?? ""),
        niche: String(formData.get("niche") ?? ""),
        logoUrl,
        headerArtUrl,
        rssFeedUrl: String(formData.get("rssFeedUrl") ?? ""),
        themePreset: String(formData.get("themePreset") ?? "classic"),
        projectDescription: String(formData.get("projectDescription") ?? ""),
        editorialStyleNotes: String(formData.get("editorialStyleNotes") ?? ""),
        targetAudience: String(formData.get("targetAudience") ?? ""),
        defaultArticleTone: String(formData.get("defaultArticleTone") ?? "profissional"),
        socialInstagram: String(formData.get("socialInstagram") ?? ""),
        socialFacebook: String(formData.get("socialFacebook") ?? ""),
        socialYoutube: String(formData.get("socialYoutube") ?? ""),
        footerContactText: String(formData.get("footerContactText") ?? ""),
        menuContactText: String(formData.get("menuContactText") ?? ""),
        autoPublishWeekdays: String(formData.get("autoPublishWeekdays") ?? ""),
        autoPublishHourUtc: String(formData.get("autoPublishHourUtc") ?? "")
      });
      return Astro.redirect(`/admin/tenants?hostname=${encodeURIComponent(hostname)}&ok=1`);
    } catch (error) {
      const message = error instanceof Error ? error.message : "Nao foi possivel salvar o tenant.";
      return Astro.redirect(`/admin/tenants?hostname=${encodeURIComponent(hostname)}&err=${encodeURIComponent(message)}`);
    }
  }

  if (action === "clone_visual") {
    const hostname = String(formData.get("hostname") ?? "");
    const sourceHostname = String(formData.get("sourceHostname") ?? "");
    try {
      if (!hostname) throw new Error("Tenant alvo inválido.");
      if (!sourceHostname) throw new Error("Informe o tenant de origem.");
      const ok = await copyTenantVisualSettings(sourceHostname, hostname);
      if (!ok) throw new Error("Não foi possível copiar o visual (origem/alvo inválidos).");
      return Astro.redirect(`/admin/tenants?hostname=${encodeURIComponent(hostname)}&ok=1`);
    } catch (error) {
      const message = error instanceof Error ? error.message : "Falha ao copiar visual.";
      return Astro.redirect(`/admin/tenants?hostname=${encodeURIComponent(hostname)}&err=${encodeURIComponent(message)}`);
    }
  }
}

const sites = await listSites();
const selected = new URL(Astro.request.url).searchParams.get("hostname") ?? sites[0]?.hostname ?? "";
const tenant = selected ? await getTenantByHostname(selected) : null;
const saved = new URL(Astro.request.url).searchParams.get("ok") === "1";
const errorMessage = new URL(Astro.request.url).searchParams.get("err");
const currentOrigin = resolvePublicOrigin(Astro.request.url, Astro.request);
const tenantPublicUrl = tenant ? buildTenantPublicUrl(currentOrigin, tenant.hostname) : "";
---

<AdminLayout title="Tenant | IAE Blog Factory">
  <section class="rounded-2xl bg-white p-5 shadow-sm">
    <h2 class="text-xl font-semibold">Criar novo tenant</h2>
    <form method="POST" class="mt-4 grid gap-3 md:grid-cols-4">
      <input type="hidden" name="action" value="create" />
      <input class="rounded-lg border border-slate-300 px-3 py-2" name="hostname" placeholder="cliente.com.br (prod) ou tenant-dev (dev)" required />
      <input class="rounded-lg border border-slate-300 px-3 py-2" name="brandName" placeholder="Nome do blog" required />
      <input class="rounded-lg border border-slate-300 px-3 py-2" name="niche" placeholder="Nicho" required />
      <button class="rounded-lg bg-indigo-600 px-4 py-2 font-semibold text-white hover:bg-indigo-500" type="submit">
        Criar
      </button>
    </form>
  </section>

  <section class="mt-6 rounded-2xl bg-white p-5 shadow-sm">
    <form method="GET" class="flex flex-wrap items-end gap-3">
      <label class="text-sm">
        <span class="mb-1 block font-medium">Tenant para configurar</span>
        <select class="rounded-lg border border-slate-300 px-3 py-2" name="hostname">
          {sites.map((site) => (
            <option value={site.hostname} selected={site.hostname === selected}>
              {site.hostname}
            </option>
          ))}
        </select>
      </label>
      <button class="rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700" type="submit">Abrir</button>
    </form>
  </section>

  {saved && <p class="mt-4 rounded-lg bg-emerald-100 px-3 py-2 text-sm text-emerald-900">Tenant salvo com sucesso.</p>}
  {errorMessage && <p class="mt-4 rounded-lg bg-rose-100 px-3 py-2 text-sm text-rose-900">{errorMessage}</p>}

  {tenant && (
    <section class="mt-6 rounded-2xl bg-white p-5 shadow-sm">
      <h3 class="text-lg font-semibold">{tenant.hostname}</h3>
      <div class="mt-2 rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700">
        URL pública de teste deste tenant:
        <a class="ml-1 font-semibold text-indigo-700 hover:underline" href={tenantPublicUrl} target="_blank" rel="noopener noreferrer">
          {tenantPublicUrl}
        </a>
      </div>
      <form method="POST" enctype="multipart/form-data" class="mt-4 grid gap-3 md:grid-cols-2">
        <input type="hidden" name="action" value="save" />
        <input type="hidden" name="hostname" value={tenant.hostname} />

        <label class="text-sm">
          <span class="mb-1 block">Nome do blog</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="brandName" value={tenant.brandName} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Nicho</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="niche" value={tenant.niche} />
        </label>

        <label class="text-sm">
          <span class="mb-1 block">Logo (URL)</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="logoUrl" value={tenant.logoUrl ?? ""} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Upload de logo (PNG/JPG/WEBP)</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" type="file" name="logoFile" accept="image/png,image/jpeg,image/webp" />
          <span class="mt-1 block text-xs text-slate-500">Se enviar arquivo, ele substitui o campo de URL acima.</span>
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Arte da testeira (URL)</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="headerArtUrl" value={tenant.headerArtUrl ?? ""} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Upload da testeira (PNG/JPG/WEBP)</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" type="file" name="headerArtFile" accept="image/png,image/jpeg,image/webp" />
          <span class="mt-1 block text-xs text-slate-500">
            Faixa horizontal (~1920×320). Se enviar arquivo, substitui a URL. Deixe a URL vazia e salve para remover a arte.
          </span>
        </label>
        <label class="text-sm">
          <span class="mb-1 block">RSS feed principal</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="rssFeedUrl" value={tenant.rssFeedUrl ?? ""} />
        </label>

        <label class="text-sm">
          <span class="mb-1 block">Paleta de cores</span>
          <select class="w-full rounded-lg border border-slate-300 px-3 py-2" name="themePreset">
            <option value="classic" selected={tenant.themePreset === "classic"}>Vintage Rock</option>
            <option value="urban" selected={tenant.themePreset === "urban"}>Seriedade</option>
            <option value="regional" selected={tenant.themePreset === "regional"}>Viajantes</option>
            <option value="premium" selected={tenant.themePreset === "premium"}>Tech Review</option>
            <option value="education" selected={tenant.themePreset === "education"}>Educação 5.0</option>
          </select>
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Tom padrão da IA</span>
          <select class="w-full rounded-lg border border-slate-300 px-3 py-2" name="defaultArticleTone">
            <option value="profissional" selected={tenant.editorial.defaultArticleTone === "profissional"}>Profissional</option>
            <option value="didatico" selected={tenant.editorial.defaultArticleTone === "didatico"}>Didático</option>
            <option value="direto" selected={tenant.editorial.defaultArticleTone === "direto"}>Direto</option>
          </select>
        </label>

        <label class="text-sm md:col-span-2">
          <span class="mb-1 block">Descrição do projeto (objetivo real do blog)</span>
          <textarea class="min-h-[100px] w-full rounded-lg border border-slate-300 px-3 py-2" name="projectDescription">{tenant.editorial.projectDescription ?? ""}</textarea>
        </label>
        <label class="text-sm md:col-span-2">
          <span class="mb-1 block">Estilo, tipos de conteúdo e instruções para IA</span>
          <textarea class="min-h-[90px] w-full rounded-lg border border-slate-300 px-3 py-2" name="editorialStyleNotes">{tenant.editorial.editorialStyleNotes ?? ""}</textarea>
        </label>
        <label class="text-sm md:col-span-2">
          <span class="mb-1 block">Público-alvo</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="targetAudience" value={tenant.editorial.targetAudience ?? ""} />
        </label>

        <label class="text-sm">
          <span class="mb-1 block">Instagram</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="socialInstagram" value={tenant.social.instagram ?? ""} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Facebook</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="socialFacebook" value={tenant.social.facebook ?? ""} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">YouTube</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="socialYoutube" value={tenant.social.youtube ?? ""} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Contato do menu</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="menuContactText" value={tenant.contact.menuText ?? ""} />
        </label>
        <label class="text-sm md:col-span-2">
          <span class="mb-1 block">Dados de contato do rodapé</span>
          <textarea class="min-h-[70px] w-full rounded-lg border border-slate-300 px-3 py-2" name="footerContactText">{tenant.contact.footerText ?? ""}</textarea>
        </label>

        <label class="text-sm">
          <span class="mb-1 block">Dias de publicação (UTC, ex: 1,3,5)</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" name="autoPublishWeekdays" value={tenant.editorial.autoPublishWeekdays ?? ""} />
        </label>
        <label class="text-sm">
          <span class="mb-1 block">Hora de publicação (UTC, 0-23)</span>
          <input class="w-full rounded-lg border border-slate-300 px-3 py-2" type="number" min="0" max="23" name="autoPublishHourUtc" value={tenant.editorial.autoPublishHourUtc ?? ""} />
        </label>

        <button class="rounded-lg bg-slate-900 px-4 py-2 font-semibold text-white hover:bg-slate-700 md:col-span-2" type="submit">
          Salvar configuração do tenant
        </button>
      </form>
      <div class="mt-4 rounded-lg border border-slate-200 bg-slate-50 p-3">
        <p class="text-sm text-slate-700">Copiar visual de outro tenant (tema, logo, header, redes e contato):</p>
        <form method="POST" class="mt-2 flex flex-wrap items-end gap-3">
          <input type="hidden" name="action" value="clone_visual" />
          <input type="hidden" name="hostname" value={tenant.hostname} />
          <label class="text-sm">
            <span class="mb-1 block font-medium">Tenant de origem</span>
            <select class="rounded-lg border border-slate-300 px-3 py-2" name="sourceHostname" required>
              {sites
                .filter((s) => s.hostname !== tenant.hostname)
                .map((s) => (
                  <option value={s.hostname}>{s.hostname}</option>
                ))}
            </select>
          </label>
          <button class="rounded-lg bg-indigo-600 px-4 py-2 font-semibold text-white hover:bg-indigo-500" type="submit">
            Copiar visual para {tenant.hostname}
          </button>
        </form>
      </div>
    </section>
  )}
</AdminLayout>
