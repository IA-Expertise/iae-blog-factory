ADMIN_USER=admin
ADMIN_PASSWORD=admin123
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1
CRON_SECRET=
# Opcional: hostnames com comentários públicos liberados (csv). Ex.: historei.00,vinil.local
# COMMENTS_ENABLED_HOSTS=historei.00
# Opcional: origem pública para canonical e OG em produção (evita localhost em compartilhamento).
# PUBLIC_SITE_ORIGIN=https://seu-dominio.com

# Opcional: mesmo script do AdSense no <head>. Formato: ca-pub- seguido só de números. Usado se Monetização do tenant não tiver client válido.
# PUBLIC_ADSENSE_CLIENT=ca-pub-0000000000000000
# Opcional: Google Analytics 4 para páginas públicas dos tenants (ex.: G-XXXXXXXXXX).
# PUBLIC_GA4_ID=G-XXXXXXXXXX

# Opcional: capas geradas em object storage (Cloudflare R2 ou AWS S3). Sem estas variáveis, usa disco + /api/media/generated/
# R2: crie bucket, token S3 API, domínio público (r2.dev ou custom host) e preencha S3_PUBLIC_BASE_URL com a URL base que o browser usa.
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=iae-blog-covers
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# S3_KEY_PREFIX=covers
