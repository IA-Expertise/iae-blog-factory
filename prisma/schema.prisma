generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String             @id @default(cuid())
  hostname           String             @unique
  brandName          String
  niche              String
  heroTitle          String
  heroSubtitle       String
  heroCtaLabel       String
  heroCtaHref        String
  heroImage          String
  themePrimary       String
  themeSecondary     String
  themeAccent        String
  themeBackground    String
  themeSurface       String
  themeText          String
  themeHeadingFont   String
  themeBodyFont      String
  adProvider         String             @default("adsense")
  adsEnabled         Boolean            @default(true)
  adClient           String
  adTopSlot          String
  adSidebarSlot      String
  adInContentSlot    String
  adFooterSlot       String
  amazonEnabled      Boolean            @default(true)
  affiliateNetwork   String
  affiliateTrackingId String
  logoUrl             String?
  rssFeedUrl          String?
  themePreset         String             @default("classic")
  projectDescription  String?
  editorialStyleNotes String?
  targetAudience      String?
  defaultArticleTone  String             @default("profissional")
  socialInstagram     String?
  socialFacebook      String?
  socialYoutube       String?
  footerContactText   String?
  menuContactText     String?
  autoPublishWeekdays String?
  autoPublishHourUtc  Int?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  posts              Post[]
  affiliateProducts  AffiliateProduct[]
  generationJobs     GenerationJob[]
  articlePitches     ArticlePitch[]
}

model ArticlePitch {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monthKey    String
  title       String
  summary     String
  status      String   @default("SUGGESTED")
  postId      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, monthKey])
  @@index([status])
}

model Post {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title              String
  slug               String
  category           String
  image              String
  excerpt            String?
  content            String?
  status             String    @default("DRAFT")
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  publishedAt        DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([scheduledPublishAt])
}

model AffiliateProduct {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title    String
  cta      String
  url      String

  @@index([tenantId])
}

model GenerationJob {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  keyword     String
  tone        String
  status      String
  resultTitle String?
  resultSlug  String?
  resultImage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
}
